# =========================
# AIyouPlayer 环境变量示例
# =========================

# --- AI Provider ---
# 兼容 Anthropic 协议的服务（推荐 DeepSeek，国内访问稳定且额度充足）
# DeepSeek API Key 申请：https://platform.deepseek.com/api_keys
ANTHROPIC_BASE_URL=https://api.deepseek.com
ANTHROPIC_API_KEY=replace-with-your-key

# 可选：指定模型 ID（默认走 SDK 内置）
# AI_MODEL=deepseek-chat

# --- 本地音频库 ---
# 默认在 ~/Documents/aiyou-player 下生成
# AUDIO_LIB_DIR=/absolute/path/to/library

# --- B 站抓取（可选）---
# 登录后浏览器 cookie 里的 SESSDATA，能解锁更高码率与更宽松限速
# BILI_SESSDATA=

# 后台并发下载数（默认 3）
# BILI_CONCURRENCY=3

# 单个音频流下载超时（毫秒，默认 120000）
# BILI_DOWNLOAD_TIMEOUT_MS=120000

# 系统 ffmpeg 路径；不安装时下载结果保留 .m4a，安装后自动转 320k MP3
# 安装：`brew install ffmpeg`
# FFMPEG_BIN=ffmpeg
